# Environment Configuration
# Copy to .env and fill in your API keys

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/5secondanswers
DB_HOST=localhost
DB_PORT=5432
DB_NAME=5secondanswers
DB_USER=postgres
DB_PASSWORD=your_password

# Server
PORT=5000
NODE_ENV=development

# AI Routing
# FAST -> Groq
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# SMART AI -> Mixtral (OpenRouter)
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://5second.app
OPENROUTER_APP_TITLE=5SecondAnswers
OPENROUTER_SMART_MODEL=mistralai/mixtral-8x7b-instruct
OPENROUTER_MODEL_COMPLEX=mistralai/mixtral-8x22b-instruct

# BRAIN AI -> NVIDIA Nemotron Super
NEMOTRON_API_KEY=nvapi-your-nemotron-key-here
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_BRAIN_MODEL=nvidia/nemotron-3-super-120b-a12b

# AI behavior
AI_ROUTING_ENABLED=true
AI_HTTP_TIMEOUT_MS=30000
AI_MAX_RETRIES=2
AI_RETRY_BASE_MS=1000
AI_CHAT_MAX_CONCURRENT=5
AI_CHAT_MIN_TIME_MS=200
AI_QUESTION_TEMPERATURE=0.7
AI_SENTIMENT_TEMPERATURE=0.25
AI_COMMENT_TEMPERATURE=0.82

# Fact-Check API
GOOGLE_FACT_CHECK_API_KEY=AIza-your-google-key-here
GOOGLE_FACT_CHECK_LANG=en

# Trending sources
YOUTUBE_API_KEY=AIza-your-youtube-key-here
NEWSAPI_API_KEY=your_newsapi_key_here
TREND_SOURCE_LIMIT_PER_SOURCE=6
TREND_SOURCE_TOTAL_LIMIT=20
TREND_SOURCE_AI_ENRICH_LIMIT=5
TREND_SOURCE_CACHE_TTL_MS=120000
TREND_SOURCE_USER_AGENT=Mozilla/5.0 (compatible; 5SecondAnswerBot/1.0; +https://5second.app)
LIVE_NEWS_CACHE_TTL_MS=90000
PERSISTED_TREND_MAX_AGE_MS=1800000
MIN_PERSISTED_TREND_ITEMS=6
TRENDING_WARM_COUNTRIES=AL,XK,US,GB
TRENDING_WARM_CRON=*/5 * * * *
TRENDING_WARM_ON_START=true

# Admin
ADMIN_KEY=admin-secret-key-123

# Frontend
FRONTEND_URL=http://localhost:3000
