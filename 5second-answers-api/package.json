{
  "name": "5second-answers-api",
  "version": "1.0.0",
  "description": "5-Second Answers API - Global Micro Q&A Platform",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "knex seed:run",
    "db:reset": "knex migrate:rollback && knex migrate:latest && knex seed:run",
    "ai:batch-comments": "node scripts/ai-comment-batch-test.js",
    "worker:live-news": "node scripts/live-news-worker.js",
    "test": "jest"
  },
  "keywords": [
    "5-second",
    "q&a",
    "micro",
    "video",
    "social",
    "answers"
  ],
  "author": "5-Second Answers Team",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.6.5",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "expo-audio": "^1.1.1",
    "expo-image-picker": "~17.0.10",
    "expo-video": "^3.0.15",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "form-data": "^4.0.0",
    "franc": "^6.2.0",
    "groq-sdk": "^1.1.2",
    "ioredis": "^5.10.1",
    "knex": "^3.1.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
